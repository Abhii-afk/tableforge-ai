# Copy this file to .env and fill in your values

# PostgreSQL Configuration
# On Windows, use 127.0.0.1 if localhost fails (IPv6 issue)
DB_HOST=127.0.0.1
DB_PORT=5433
DB_NAME=wtc
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Docker Compose Environment (must match DB_* variables above)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_db_password_here
POSTGRES_DB=wtc

# Scripts Connection String
DATABASE_URL=postgresql://postgres:your_db_password_here@127.0.0.1:5433/wtc

# Google Gemini API Key (required for AI query translation)
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
